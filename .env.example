# Variables de entorno para el Bot de Platica
# Copia este archivo como .env y rellena los valores

# Token del bot de Telegram (obtenido de @BotFather)
TELEGRAM_TOKEN=tu_token_aqui

# Tu ID de Telegram personal (para recibir notificaciones de ventas)
# Puedes obtenerlo enviando /start a @userinfobot
TU_TELEGRAM_ID=123456789

# Correo de Gmail del admin
GMAIL_USER=tu_email@gmail.com

# Contraseña de aplicación de Gmail (NO tu contraseña normal)
# Ver gmail_setup.md para instrucciones
GMAIL_PASSWORD=abcd_efgh_ijkl_mnop

# Ruta al archivo CSV con credenciales (opcional, default: credentials.csv)
# CSV_PATH=credentials.csv
